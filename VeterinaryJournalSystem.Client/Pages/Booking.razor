@page "/booking"
@inject OwnerApiService OwnerApiService
@inject PetApiService PetApiService
@inject VisitApiService VisitApiService
@using VeterinaryJournalSystem.Client.Services

<div class="booking-page">
    <h1>Tidsbokning</h1>
    <p>Sök först efter djurägaren med personnummer.</p>

    @if (!showCreateOwnerForm && !showCreatePetForm)
    {
        <div class="booking-card">
            <label>Personnummer</label>
            <input @bind="personalNumber" placeholder="XXXXXX-XXXX" />

            <button @onclick="SearchOwner">Sök ägare</button>

            @if (!string.IsNullOrEmpty(message))
            {
                <p>@message</p>
            }
        </div>

        @if (foundOwner != null)
        {
            <div class="booking-card">
                <h3>@foundOwner.FullName</h3>
                <p>@foundOwner.PhoneNumber</p>
                <p>@foundOwner.PersonalNumber</p>

                <h4>Djur</h4>

                @if (ownerPets.Any())
                {
                    @foreach (var pet in ownerPets)
                    {

                        <h4>@pet.Name</h4>
                        <p> @pet.Species - @pet.Breed  </p>
                        <button @onclick="() => ShowCreateVisitForm(pet)">
                            Boka besök
                        </button>
                    }
                }
                else
                {
                    <p>Inga djur registrerade.</p>
                }

                <button @onclick="() => showCreatePetForm = true">
                    Lägg till husdjur
                </button>
            </div>
        }
        else if (searched)
        {
            <div class="booking-card">
                <button @onclick="ShowCreateOwnerForm">
                    Skapa ny ägare
                </button>
            </div>
        }
    }

    @if (showCreateOwnerForm)
    {
        <div class="booking-card">
            <h3>Skapa ny ägare</h3>

            <label>Personnummer</label>
            <input @bind="newOwnerPersonalNumber" />

            <label>Namn</label>
            <input @bind="newOwnerFullName" placeholder="För- och efternamn" />

            <label>Telefonnummer</label>
            <input @bind="newOwnerPhoneNumber" placeholder="0701234567" />

            <label>Kommentar</label>
            <input @bind="newOwnerComment" placeholder="Valfri kommentar" />

            <button @onclick="CreateOwner">Skapa ägare</button>

            <button @onclick="BackToSearch">Tillbaka</button>
        </div>
    }

    @if (showCreatePetForm && foundOwner != null)
    {
        <div class="booking-card">
            <h3>Lägg till husdjur</h3>

            <label>Namn</label>
            <input @bind="newPetName" />

            <label>Art</label>
            <input @bind="newPetSpecies" placeholder="Cat, Dog..." />

            <label>Ras</label>
            <input @bind="newPetBreed" />

            <label>Födelsedatum</label>
            <input type="date" @bind="newPetDateOfBirth" />

            <label>
                <input type="checkbox" @bind="newPetIsInsured" />
                Försäkrad
            </label>

            <button @onclick="CreatePet">Spara husdjur</button>
            <button @onclick="BackToOwner">
                Tillbaka
            </button>
        </div>

    }
    @if (showCreateVisitForm && selectedPet != null)
    {
        <div class="booking-card">
            <h3>Boka besök för @selectedPet.Name</h3>

            <label>Datum och tid</label>
            <input type="datetime-local" @bind="newVisitScheduledAt" />

            <label>Anledning</label>
            <input @bind="newVisitReason" placeholder="Ex. Skadat ben" />

            <button @onclick="CreateVisit">
                Boka besök
            </button>

            <button @onclick="() => showCreateVisitForm = false">
                Tillbaka
            </button>
        </div>
    }



</div>



@code {
    private string personalNumber = string.Empty;
    private string message = string.Empty;

    private OwnerDto? foundOwner;
    private bool searched = false;

    private bool showCreateOwnerForm = false;
    private bool showCreatePetForm = false;

    private string newOwnerFullName = string.Empty;
    private string newOwnerPhoneNumber = string.Empty;
    private string newOwnerPersonalNumber = string.Empty;
    private string? newOwnerComment;

    private List<PetDto> ownerPets = new();

    private string newPetName = string.Empty;
    private string newPetSpecies = string.Empty;
    private string newPetBreed = string.Empty;
    private bool newPetIsInsured = false;
    private DateTime newPetDateOfBirth = DateTime.Today;

    private async Task SearchOwner()
    {
        searched = true;
        showCreateOwnerForm = false;
        showCreatePetForm = false;
        message = string.Empty;
        ownerPets.Clear();

        foundOwner = await OwnerApiService.SearchOwnerByPersonalNumberAsync(personalNumber);

        if (foundOwner == null)
        {
            message = "Ingen ägare hittades. Du kan skapa en ny ägare.";
            return;
        }

        ownerPets = await PetApiService.GetPetsByOwnerIdAsync(foundOwner.Id);
    }

    private void ShowCreateOwnerForm()
    {
        newOwnerPersonalNumber = personalNumber;
        showCreateOwnerForm = true;
        showCreatePetForm = false;
        message = string.Empty;
    }

    private void BackToSearch()
    {
        showCreateOwnerForm = false;
    }

    private async Task CreateOwner()
    {
        var request = new CreateOwnerRequest
        {
            FullName = newOwnerFullName,
            PhoneNumber = newOwnerPhoneNumber,
            PersonalNumber = newOwnerPersonalNumber,
            Comment = newOwnerComment
        };

        var createdOwner = await OwnerApiService.CreateOwnerAsync(request);

        if (createdOwner == null)
        {
            message = "Kunde inte skapa ägare.";
            return;
        }

        foundOwner = createdOwner;
        ownerPets = await PetApiService.GetPetsByOwnerIdAsync(foundOwner.Id);
        showCreateOwnerForm = false;
        searched = true;
        message = "Ägare skapad.";
    }

    private async Task CreatePet()
    {
        if (foundOwner == null)
        {
            message = "Ingen ägare vald.";
            return;
        }

        var request = new CreatePetRequest
        {
            Name = newPetName,
            Species = newPetSpecies,
            Breed = newPetBreed,
            IsInsured = newPetIsInsured,
            DateOfBirth = newPetDateOfBirth,
            OwnerId = foundOwner.Id
        };

        var createdPet = await PetApiService.CreatePetAsync(request);

        if (createdPet == null)
        {
            message = "Kunde inte skapa husdjur.";
            return;
        }

        ownerPets.Add(createdPet);

        newPetName = string.Empty;
        newPetSpecies = string.Empty;
        newPetBreed = string.Empty;
        newPetIsInsured = false;
        newPetDateOfBirth = DateTime.Today;

        showCreatePetForm = false;
        message = "Husdjuret skapades.";
    }
    private void BackToOwner()
    {
        showCreatePetForm = false;
    }

    private bool showCreateVisitForm = false;
    private PetDto? selectedPet;

    private DateTime newVisitScheduledAt = DateTime.Now;
    private string newVisitReason = string.Empty;

    private void ShowCreateVisitForm(PetDto pet)
    {
        selectedPet = pet;
        showCreateVisitForm = true;
        showCreatePetForm = false;
        message = string.Empty;
    }

    private async Task CreateVisit()
    {
        if (selectedPet == null)
        {
            message = "Inget husdjur valt.";
            return;
        }

        var request = new CreateVisitRequest
        {
            PetId = selectedPet.Id,
            ScheduledAt = newVisitScheduledAt,
            ReasonForVisit = newVisitReason
        };

        var createdVisit = await VisitApiService.CreateVisitAsync(request);

        if (createdVisit == null)
        {
            message = "Kunde inte boka besök.";
            return;
        }

        showCreateVisitForm = false;
        newVisitReason = string.Empty;
        newVisitScheduledAt = DateTime.Now;

        message = "Besöket bokades.";
    }
}